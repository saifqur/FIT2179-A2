    },
    {
      "mark": { "type": "point", "filled": true, "size": 120, "color": "#1a6fad" },
      "encoding": {
        "y": {
          "field": "state",
          "type": "ordinal",
          "sort": "-inactive_pct",
          "title": null
        },
        "x": {
          "field": "inactive_pct",
          "type": "quantitative",
          "scale": { "domain": [32, 54] }
        },
        "tooltip": [
          { "field": "state",        "title": "State" },
          { "field": "inactive_pct", "title": "% Inactive", "format": ".1f" }
        ]
