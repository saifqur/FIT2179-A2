{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Adults Not Meeting Physical Activity Guidelines by State (2022)",
  "width": 500,
  "height": 300,
  "projection": { "type": "mercator" },
  "layer": [
    {
      "data": {
		"url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "values": [
                { "state": "NSW", "inactive_pct": 43.2 },
                { "state": "VIC", "inactive_pct": 40.1 },
                { "state": "QLD", "inactive_pct": 45.8 },
                { "state": "SA",  "inactive_pct": 44.5 },
                { "state": "WA",  "inactive_pct": 42.9 },
                { "state": "TAS", "inactive_pct": 50.2 },
                { "state": "NT",  "inactive_pct": 44.1 },
                { "state": "ACT", "inactive_pct": 36.7 }
              ]
            },
            "key": "state",
            "fields": ["inactive_pct"]
          }
        }
      ],
      "mark": { "type": "geoshape", "stroke": "#fff", "strokeWidth": 1 },
      "encoding": {
        "color": {
          "field": "inactive_pct",
          "type": "quantitative",
          "scale": { "scheme": "blues", "domain": [30, 55] },
          "legend": { "title": "%" }
        },
        "tooltip": [
          { "field": "properties.STATE_NAME", "title": "State" },
          { "field": "inactive_pct", "title": "Inactive (%)", "format": ".1f" }
        ]
      }
    }
  ]
}
