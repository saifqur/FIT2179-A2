{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "% Not Meeting Physical Activity Guidelines by Age Group (2022)",
  "width": 400,
  "height": 260,
  "data": {
    "values": [
      { "age": "15–17", "pct": 83 },
      { "age": "18–24", "pct": 36 },
      { "age": "25–34", "pct": 38 },
      { "age": "35–44", "pct": 40 },
      { "age": "45–54", "pct": 43 },
      { "age": "55–64", "pct": 47 },
      { "age": "65+",   "pct": 57 }
    ]
  },
  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 3,
    "cornerRadiusTopRight": 3
  },
  "encoding": {
    "x": {
      "field": "age",
      "type": "ordinal",
      "title": "Age Group",
      "axis": { "labelAngle": 0 }
    },
    "y": {
      "field": "pct",
      "type": "quantitative",
      "title": "% Not Meeting Guidelines",
      "scale": { "domain": [0, 100] }
    },
    "color": {
      "field": "pct",
      "type": "quantitative",
      "scale": { "scheme": "oranges", "domain": [30, 90] },
      "legend": null
    },
    "tooltip": [
      { "field": "age", "title": "Age Group" },
      { "field": "pct", "title": "% Not Meeting Guidelines" }
    ]
  }
}
